# Environment
.env
.venv/

# OS
.DS_Store
Thumbs.db

# Claude Code state
.claude/data/
*.db

# Python
__pycache__/
*.pyc

# Generated plans
.agent/

# Secrets & credentials
.env.*
*.pem
*.key
credentials.json
google_token.json
**/token.json
**/client_secret*.json

# State (regenerable)
.claude/data/state/*.json

# Python virtualenv
.claude/.venv/

# Flush outcome log (regenerable)
.claude/data/state/flush.log

# Daily-log lock files (runtime artifacts from file_lock())
Brain/Memory/daily/*.lock

# Keep the env template checked in
!.env.example
