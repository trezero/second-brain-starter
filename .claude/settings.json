{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/.venv/bin/python3 .claude/hooks/session-start-context.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/.venv/bin/python3 .claude/hooks/pre-compact-flush.py",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/.venv/bin/python3 .claude/hooks/session-end-flush.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
